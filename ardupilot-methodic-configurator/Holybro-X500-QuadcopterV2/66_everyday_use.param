BATT_ARM_VOLT,22.8  # Everyday arming threshold. 3.8V/cell × 6 = 22.8V. Slightly below step 11's 23.6V to allow arming with a good but not fully charged pack.
LOG_BITMASK,2277374  # Everyday logging: GPS, System Performance, Control Tuning, RC input, IMU, Missions, Battery, PID, Compass, Motors.
QUIK_ENABLE,0  # Disable the VTOL-Quicktune Lua script. It was enabled in step 29 and is no longer needed post-tuning.
