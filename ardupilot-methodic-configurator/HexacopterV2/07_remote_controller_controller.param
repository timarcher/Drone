ARMING_RUDDER,2  # Allow arm or disarm by rudder input.
BRD_ALT_CONFIG,0  # Stay at default. This is used to select an alternative hardware config.
FLTMODE_CH,5  # RC channel to use for flight mode control. 5 is the default, so we stay with that.
RC5_OPTION,0  # Do nothing. Leave unassigned as flight mode is setup on channel 5 by default.
RC6_OPTION,0  # Leave at 0. We map RC6 to SERVO9_FUNCTION below to control the navigation lights.
RC7_OPTION,11  # Enable/Disable fence
RC8_OPTION,40  # Enable/Disable Proximity Sensor.
RC9_OPTION,0  # Do nothing. Function assigned to rc channel 9. For example, we could pick things like "Motor Emergency Stop", "Lost rover Sound", etc
SERVO9_FUNCTION,56  # Configure for RC Pass thru. 56 = RCIN6 which means RC channel 6 gets output to SERVO9.
