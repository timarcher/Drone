ARMING_RUDDER,2  # Enable rudder (yaw stick) arming and disarming. 2=arm and disarm allowed.
BRD_ALT_CONFIG,0  # Board alternate pin configuration. 0=default pin mapping for CubeOrangePlus.
FLTMODE_CH,5  # RC channel 5 is the flight mode selector switch.
RC5_OPTION,0  # Channel 5 is the flight mode selector (FLTMODE_CH=5). No additional RC option needed.
RC6_OPTION,0  # Channel 6 controls Flytron strobe lights via SERVO9 pass-through (see SERVO9_FUNCTION).
RC7_OPTION,11  # Channel 7: Enable/disable geofence in flight.
RC8_OPTION,40  # Channel 8: Enable/disable proximity sensor avoidance in flight.
RC9_OPTION,0  # Channel 9: Unassigned.
SERVO9_FUNCTION,56  # SERVO9 outputs RC channel 6 signal (RC pass-through). Used for Flytron STROBON Cree v2 strobe lights.
