DID_CANDRIVER,1  # OpenDroneID uses DroneCAN driver 1. The RemoteID module is connected on CAN1.
DID_ENABLE,1  # Enable OpenDroneID (FAA Remote ID) broadcast. Required for legal operation.
DID_OPTIONS,2  # Bitmask. Bit 1 (value 2) = lock UAS ID once the first valid Basic ID message is received. Prevents accidental ID changes after initial setup.
