FS_THR_ENABLE,1  # Enable throttle-based RC failsafe. 1=Always RTL (or Land if no GPS). Throttle below FS_THR_VALUE triggers failsafe.
FS_THR_VALUE,975  # RC failsafe trigger threshold in microseconds on the throttle channel. Signal below this value = failsafe.
RC_FS_TIMEOUT,1  # RC failsafe will trigger this many seconds after loss of RC signal.
RC_OPTIONS,32  # Bitmask. Bit 5 (value 32): ignore RC receiver failsafe flag — use throttle-only detection to avoid false triggers with Herelink.
RC_PROTOCOLS,1  # Selected in the component editor
RSSI_TYPE,0  # No analog RSSI sensor. Herelink reports link quality internally via MAVLink.
